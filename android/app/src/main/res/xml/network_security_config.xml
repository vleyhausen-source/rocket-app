<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config fuer Rocket Rise
    Erlaubt nur HTTPS-Verbindungen im Release-Build.
    Cleartext (HTTP) ist deaktiviert ausser fuer lokale Debug-Adressen.
    Dokumentation: https://developer.android.com/training/articles/security-config
-->
<network-security-config>
    <!-- Produktionsregel: Nur HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Nur vom System vertrauenswuerdige CA-Zertifikate akzeptieren -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Ausnahme: localhost fuer Flutter-Debug-Verbindungen (Hot Reload etc.) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
    </domain-config>
</network-security-config>
