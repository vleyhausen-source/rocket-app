<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        LaunchTheme: Sichtbar während Flutter-Engine startet (Splash).
        Elternt von Theme.AppCompat.NoActionBar statt dem deprecated
        @android:style/Theme.Light.NoTitleBar (der intern windowFullscreen-Flags
        setzt, die in API 35 als deprecated gelten und die Play-Console-Warnung
        "nicht mehr unterstützte APIs für randlose Anzeige" auslösen).
        windowLayoutInDisplayCutoutMode=shortEdges: Content darf in Notch-/Kerben-
        Bereiche an kurzen Seiten reichen — wichtig für Vollbild-Games.
    -->
    <style name="LaunchTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!--
        NormalTheme: Hintergrund des Android-Windows hinter der Flutter-UI.
        Ab Android 15 (API 35) wird Edge-to-Edge automatisch erzwungen —
        enableEdgeToEdge() in MainActivity setzt die Insets korrekt.
        SystemChrome.setEnabledSystemUIMode(immersiveSticky) in main.dart
        übernimmt danach die vollständige System-UI-Kontrolle für das Spiel.
    -->
    <style name="NormalTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
