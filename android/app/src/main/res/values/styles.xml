<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        LaunchTheme: Sichtbar während Flutter-Engine startet (Splash).
        Theme.AppCompat.NoActionBar: ersetzt deprecated Theme.Light.NoTitleBar.
        windowLayoutInDisplayCutoutMode=shortEdges: Content reicht in Notch-Bereiche.
        windowOptOutEdgeToEdgeEnforcement=true: verhindert, dass Android 16 Edge-to-Edge
        erzwingt bevor Flutter bereit ist (bekanntes Problem auf Xiaomi HyperOS 3,
        bei dem das frühe Erzwingen zu einem schwarzem Frame führen kann).
        Flutter übernimmt danach via SystemChrome.setEnabledSystemUIMode(immersiveSticky)
        die vollständige System-UI-Kontrolle.
    -->
    <style name="LaunchTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>

    <!--
        NormalTheme: Hintergrund des Android-Windows hinter der Flutter-UI.
        windowIsTranslucent=false: explizit opak – verhindert schwarzen Hintergrund-Blitz
        auf Xiaomi HyperOS wenn das Window-Compositing anders ist als auf Stock-Android.
    -->
    <style name="NormalTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/launch_background_color</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>
